{
  "extends": "@parcel/config-default",
  "transformers": {
    "*.md": [
      "parcel-transformer-pandoc",
      "..."
    ],
    "*.{dot,gv}": [
      "parcel-transformer-graphviz"
    ],
    "*.svg": [
      "./plugins/run-xslt3.mjs",
      "parcel-transformer-rough-svg"
    ]
  },
  "namers": [
    "parcel-namer-rewrite"
  ],
  "optimizers": {
    "*.js": [
      "@parcel/optimizer-esbuild"
    ]
  },
  "reporters": [
    "...",
    "parcel-reporter-static-files-copy"
  ]
}
