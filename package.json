{
  "private": true,
  "name": "keri.is",
  "version": "0.1.0",
  "scripts": {
    "dev": "parcel index.md",
    "build": "parcel build index.md"
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^6.4.0",
    "@gatsbyjs/parcel-namer-relative-to-cwd": "^2.11.0",
    "@parcel/transformer-sass": "^2.9.3",
    "bulma": "^0.9.4",
    "parcel": "^2.9.3",
    "parcel-namer-rewrite": "^2.0.0-rc.3",
    "parcel-transformer-pandoc": "*",
    "sharp": "^0.31.3"
  },
  "parcel-namer-rewrite": {
    "chain": "@parcel/namer-default",
    "hashing": "always",
    "rules": {
      "index.html$": "index.html",
      "(.*).html$": "$1/index.html"
    }
  }
}
