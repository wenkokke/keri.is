{
  "private": true,
  "name": "keri.is",
  "scripts": {
    "build": "npm run build:experimental-jams",
    "build:experimental-jams": "npm run build --workspace=experimental-jams"
  },
  "workspaces": [
    "parcel-transformer-pandoc",
    "experimental-jams"
  ],
  "parcel-namer-rewrite": {
    "chain": "@parcel/namer-default",
    "hashing": "always",
    "rules": {
      "index.html": "index.html",
      "(.*).html": "$1/index.html"
    }
  }
}
