---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import "@fancyapps/ui/dist/fancybox/fancybox.css";
import "../../styles/gallery.css";

function chunksOf<T>(array: T[], chunkSize: number): T[][] {
  const result = [];
  for (let i = 0; i < array.length; i += chunkSize) {
    result.push(array.slice(i, i + chunkSize));
  }
  return result;
}

const ceramics = await getCollection("ceramics");
const ceramicsSorted = ceramics.toSorted((a,b) => parseInt(b.id) - parseInt(a.id));
const ceramicsChunks = chunksOf(ceramicsSorted, 12);
const imageLoadMap = import.meta.glob<{ default: ImageMetadata }>(
  `/src/assets/images/ceramics/*.jpg`,
);
const imageDataMap = Object.fromEntries(
  await Promise.all(
    Object.entries(imageLoadMap).map(async ([filePath, imageFunc]) => {
      const imageData = await imageFunc();
      return [filePath, imageData.default];
    }),
  ),
);
---

<BaseLayout pageTitle={"a Potter"}>
  {
    ceramicsChunks.map((ceramicsChunk, _ceramicsChunkIndex) => {
      const galleryIsComplete = ceramicsChunk.length === 12;
      const galleryClassList = [
        ["gallery"],
         galleryIsComplete ? [] : ["gallery-incomplete"],
      ]
      return (
        <section class={galleryClassList.join(' ')}>
          {ceramicsChunk.map((item, itemIndex) => {
            // In even chunks, the highlight image is the 2nd (i.e., itemIndex 1),
            // whereas in odd chunks, the highlight image is the 1st.
            const itemClassList = [
              ["gallery-item"],
              galleryIsComplete ? [`gallery-item${itemIndex % 12}`] : [],
            ].flat();
            const src = `/src/assets/images/ceramics/${item.data.src}`;
            const data = imageDataMap[src];
            if (data === undefined) {
              console.log(`Could not find data for ${src}`);
            }
            const loading = itemIndex < 20 ? "eager" : "lazy";
            return (
              <div class={itemClassList.join(" ")}>
                <a
                  href={data.src}
                  data-fancybox="gallery"
                  data-caption={item.data.caption}
                >
                  <Picture
                    alt={item.data.alt}
                    layout="constrained"
                    format="webp"
                    width="1620"
                    height="1080"
                    loading={loading}
                    src={data}
                  />
                </a>
              </div>
            );
          })}
        </section>
      );
    })
  }
</BaseLayout>

<script>
  import { Fancybox } from "@fancyapps/ui/dist/fancybox/";

  Fancybox.bind("[data-fancybox]", {
    zoomEffect: false,
    Carousel: {
      Toolbar: {
        display: {
          left: [],
          middle: [],
          right: ["close"],
        },
      },
      Zoomable: {
        Panzoom: {
          protected: true,
        },
      },
      transition: "slide",
    },
  });
</script>
