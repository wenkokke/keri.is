---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import "@fancyapps/ui/dist/fancybox/fancybox.css";
import "../../styles/gallery.css";
import { chunksOf, partition, spliceAll, zipWith } from "../../constants";

// Load ceramics.
const ceramics = (await getCollection("ceramics")).toSorted(
  (x, y) => parseInt(y.id) - parseInt(x.id),
);

// Partition ceramics into regular and highlights.
const [ceramicsHighlight, ceramicsRegular] = partition(
  (x) => !!x.data.highlight,
  ceramics,
);

// Check the ratio of regular and highlighted ceramics.
const [ceramicsRegularChunkSize, ceramicsHighlightChunkSize] = [10, 2];
const ceramicsRegularChunksCount =
  ceramicsRegular.length / ceramicsRegularChunkSize;
const ceramicsHighlightChunksCount =
  /* If the last chunk is incomplete, it has no highlighted items. */
  ceramicsRegular.length % ceramicsHighlightChunkSize === 0
    ? ceramicsRegularChunksCount
    : ceramicsRegularChunksCount - 1;
const ceramicsHighlightCount =
  ceramicsHighlightChunkSize * ceramicsHighlightChunksCount;
if (ceramicsHighlightCount != ceramicsHighlight.length) {
  throw Error(
    `Expected ${ceramicsHighlightCount} highlighted ceramics, but found ${ceramicsHighlight.length}.`,
  );
}

// Merge chunks with highlights at correct position for layout.
const ceramicsChunks = zipWith(
  (xs, [y1, y2]) =>
    spliceAll(xs, [
      [2, y1],
      [7, y2],
    ]),
  chunksOf(ceramicsRegular, ceramicsRegularChunkSize),
  chunksOf(ceramicsHighlight, ceramicsHighlightChunkSize),
);

const imageLoadMap = import.meta.glob<{ default: ImageMetadata }>(
  `/src/assets/images/ceramics/*.jpg`,
);
const imageDataMap = Object.fromEntries(
  await Promise.all(
    Object.entries(imageLoadMap).map(async ([filePath, imageFunc]) => {
      const imageData = await imageFunc();
      return [filePath, imageData.default];
    }),
  ),
);
---

<BaseLayout pageTitle={"a Potter"}>
  {
    ceramicsChunks.map((ceramicsChunk, _ceramicsChunkIndex) => {
      const galleryIsComplete = ceramicsChunk.length === 12;
      const galleryClassList = [
        ["gallery"],
        galleryIsComplete ? [] : ["gallery-incomplete"],
      ];
      return (
        <section class={galleryClassList.join(" ")}>
          {ceramicsChunk.map((item, itemIndex) => {
            const itemClassList = [
              ["gallery-item"],
              galleryIsComplete ? [`gallery-item${itemIndex % 12}`] : [],
            ].flat();
            const src = `/src/assets/images/ceramics/${item.data.src}`;
            const data = imageDataMap[src];
            if (data === undefined) {
              console.log(`Could not find data for ${src}`);
            }
            const loading = itemIndex < 20 ? "eager" : "lazy";
            return (
              <div class={itemClassList.join(" ")}>
                <a
                  href={data.src}
                  data-fancybox="gallery"
                  data-caption={item.data.caption}
                >
                  <Picture
                    alt={item.data.alt}
                    layout="constrained"
                    format="webp"
                    width="1620"
                    height="1080"
                    loading={loading}
                    src={data}
                  />
                </a>
              </div>
            );
          })}
        </section>
      );
    })
  }
</BaseLayout>

<script>
  import { Fancybox } from "@fancyapps/ui/dist/fancybox/";

  Fancybox.bind("[data-fancybox]", {
    zoomEffect: false,
    Carousel: {
      Toolbar: {
        display: {
          left: [],
          middle: [],
          right: ["close"],
        },
      },
      Zoomable: {
        Panzoom: {
          protected: true,
        },
      },
      transition: "slide",
    },
  });
</script>
