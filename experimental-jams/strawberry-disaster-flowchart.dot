digraph strawberry_disaster {
  node [fontname = "Tinos";];
  
  clusterrank = local;
  compound = true;
  layout = "dot";
  margin = 0;
  rank = "same";
  rankdir = "LR";
  
  subgraph {
    cluster = true;
    margin = 25;
    style = invis;
    
    sg [label = "The Suggestion";shape = rect;id = "sg";];
  }
  
  sg:s -> c1:n;
  
  subgraph {
    cluster = true;
    margin = 25;
    style = invis;
    
    c1 [label = "Confession A";shape = rect;id = "c1";];
    c2 [label = "Confession B";shape = rect;id = "c2";];
    c3 [label = "Confession C";shape = rect;id = "c3";];
    c4 [label = "Confession D";shape = rect;id = "c4";];
  }
  
  c1:e -> c2:w;
  c2:e -> c3:w;
  c3:e -> c4:w;
  
  subgraph {
    cluster = true;
    margin = 25;
    style = invis;
    
    fb1 [label = "1st Beat A/B";shape = rect;id = "fb1";];
    fb2 [label = "1st Beat B/C";shape = rect;id = "fb2";];
    fb3 [label = "1st Beat C/D";shape = rect;id = "fb3";];
    fb4 [label = "1st Beat D/A";shape = rect;id = "fb4";];
  }
  
  c4:s -> fb1:n [constraint = false;];
  
  fb1:e -> fb2:w;
  fb2:e -> fb3:w;
  fb3:e -> fb4:w;
  
  subgraph {
    cluster = true;
    margin = 25;
    style = invis;
    
    tt [label = "The Omen";shape = rect;id = "tt";];
  }
  
  fb4:s -> tt:n;
  
  subgraph {
    cluster = true;
    margin = 25;
    style = invis;
    
    sb1 [label = "2nd Beat A/B";shape = rect;id = "sb1";];
    sb2 [label = "2nd Beat B/C";shape = rect;id = "sb1";];
    sb3 [label = "2nd Beat C/D";shape = rect;id = "sb1";];
    sb4 [label = "2nd Beat D/A";shape = rect;id = "sb1";];
  }
  
  tt:s -> sb1:n [constraint = false;];
  
  sb1:e -> sb2:w;
  sb2:e -> sb3:w;
  sb3:e -> sb4:w;
  
  subgraph {
    cluster = true;
    margin = 25;
    style = invis;
    
    td [label = "The Disaster";shape = rect;id = "td";];
  }
  
  sb4:s -> td:n;
}