{
  "src/index.md": {
    "standalone": true,
    "template": "${.}/templates/page.html",
    "metadata-file": "${.}/templates/page.yaml"
  },
  "src/*.md": [
    {
      "standalone": true,
      "template": "${.}/templates/page.html",
      "lua-filter": "${.}/../filters/bubble/bubble.lua",
      "metadata-file": "${.}/templates/page.yaml",
      "write": "${.}/../filters/html_metadata_block/html_metadata_block.lua"
    },
    {
      "read": "${.}/../filters/raw_html/raw_html.lua",
      "standalone": true,
      "template": "${.}/templates/default.html",
      "metadata-file": "${.}/templates/default.yaml"
    }
  ]
}
