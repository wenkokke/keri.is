{
  "src/index.md": {
    "standalone": true,
    "template": "${.}/templates/page.html",
    "metadata-file": "${.}/templates/page.yaml"
  },
  "src/*.md": {
    "standalone": true,
    "template": "${.}/templates/page.html",
    "lua-filter": [
      "${.}/filters/wenkokke/bubble/bubble.lua"
    ],
    "metadata-file": "${.}/templates/page.yaml"
  }
}
